{
  "functions": {
    "source": "functions"
  },
  "hosting": [
    {
      "target": "marketing",
      "public": "marketing-site/public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "cleanUrls": true,
      "rewrites": [
        {
          "source": "/datenschutz",
          "destination": "/datenschutz.html"
        },
        {
          "source": "/impressum",
          "destination": "/impressum.html"
        }
      ]
    },
    {
      "target": "app",
      "public": "build/web",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "cleanUrls": true,
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
